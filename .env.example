# =============================================================================
# A 站控制面（vpn-control-plane）— 环境变量模板
# 复制为 .env 后填写：`cp .env.example .env && php artisan key:generate`
# =============================================================================

APP_NAME="VPN Control Plane"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# 公网访问 A 站必须使用 HTTPS 真实域名（管理后台、API、易支付回调）
APP_URL=https://a.example.com

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# 数据库（当前运行环境为 MySQL；亦支持 sqlite / pgsql，见 config/database.php）
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vpn_a
DB_USERNAME=vpn_a
DB_PASSWORD=change_me

# 可选：遗留 SQLite 路径（若项目内仍引用 legacy_sqlite 连接）
# LEGACY_SQLITE_PATH=/var/www/vpn-control-plane/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# 仅在 .env 中显式填写 REDIS_URL 或 REDIS_HOST 时，应用启动会 PING Redis；成功则 cache/session/queue 使用 Redis，失败则回退 database。不填写则完全不启用 Redis 栈，按上方 CACHE_STORE / SESSION_DRIVER / QUEUE_CONNECTION
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# 彩虹易支付（分销商在线充值）— 管理后台「支付设置」可覆盖数据库，未配置时用此处
# -----------------------------------------------------------------------------
EPAY_ENABLED=false
EPAY_GATEWAY=https://pay.example.com
EPAY_PID=
EPAY_KEY=
# EPAY_NOTIFY_URL=
# EPAY_RETURN_URL=
EPAY_ALLOW_SIMULATED_RECHARGE=true

# -----------------------------------------------------------------------------
# 节点 Agent HTTP 接入（注册换取 bearer token）
# -----------------------------------------------------------------------------
# SSH 安装节点时，目标机会用此 token 请求 GET /api/v1/agent/package 拉取 Agent 源码包（与注册接口同源鉴权）
AGENT_BOOTSTRAP_TOKEN=change_me_agent_bootstrap_token
# 节点 Agent 版本号（10 位数字：日期 YYYYMMDD + 两位构建序号），SSH 部署时写入目标机
AGENT_PACKAGE_VERSION=2026032501
# 可选：覆盖默认 Agent 源码目录（含 run_agent.py）。默认使用 Laravel 根下 agent/；Monorepo 开发可指向上级 2.0/agent
# AGENT_SOURCE_PATH=/opt/vpn1/2.0/agent

# -----------------------------------------------------------------------------
# FreeRADIUS Redis 认证缓存（可选）
# -----------------------------------------------------------------------------
# 启用后，A 站在同步 radcheck 的同时写入 Redis：radius:auth:user:<username>
# 字段：password/status/expires_at/updated_at
RADIUS_REDIS_AUTH_ENABLED=false
RADIUS_REDIS_CONNECTION=default
RADIUS_REDIS_AUTH_PREFIX=radius:auth:user:
